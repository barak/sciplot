From: "Barak A. Pearlmutter" <barak+git@pearlmutter.net>
Date: Tue, 16 May 2017 15:45:13 +0100
Subject: autotools

---
 Makefile.am  | 23 +++++++++++++++++++++++
 configure.ac | 34 ++++++++++++++++++++++++++++++++++
 2 files changed, 57 insertions(+)
 create mode 100644 Makefile.am
 create mode 100644 configure.ac

diff --git a/Makefile.am b/Makefile.am
new file mode 100644
index 0000000..1708b61
--- /dev/null
+++ b/Makefile.am
@@ -0,0 +1,23 @@
+ACLOCAL_AMFLAGS = -I m4
+
+lib_LTLIBRARIES = libsciplot.la
+libsciplot_la_SOURCES = SciPlot.c SciPlotUtil.c
+libsciplot_la_LDFLAGS = -version-info 37:1:36
+
+bin_PROGRAMS = realtime xyplot
+
+realtime_SOURCES = realtime.c
+xyplot_SOURCES   = xyplot.c
+realtime_LDADD   = libsciplot.la
+xyplot_LDADD     = libsciplot.la
+
+include_HEADERS = SciPlot.h SciPlotP.h SciPlotUtil.h
+
+dist_doc_DATA = data.txt
+
+dist_doc_DATA += ANNOUNCE CHANGES LICENSE
+
+dist_doc_DATA += SciPlot.html SciPlotDemo.html SciPlotProg.html gpl.html
+dist_doc_DATA += SciPlotDemo.gif SciPlotExample.gif SciPlotTitle.gif new.gif
+
+EXTRA_DIST = Imakefile Makefile.noImake
diff --git a/configure.ac b/configure.ac
new file mode 100644
index 0000000..acc6de2
--- /dev/null
+++ b/configure.ac
@@ -0,0 +1,34 @@
+# Process this file with autoconf to produce a configure script.
+
+AC_PREREQ([2.69])
+AC_INIT([SciPlot], [1.36], [BUG-REPORT-ADDRESS])
+AC_CONFIG_SRCDIR([SciPlot.c])
+AC_CONFIG_HEADERS([config.h])
+AC_CONFIG_MACRO_DIRS([m4])
+AM_INIT_AUTOMAKE([foreign -Wall])
+
+# Checks for programs.
+AM_PROG_AR
+AC_PROG_CC
+AX_CFLAGS_WARN_ALL
+LT_INIT
+
+# Checks for libraries.
+
+AC_SEARCH_LIBS([XmCreateMainWindow],[Xm])
+AC_SEARCH_LIBS([XtAddCallback],[Xt])
+AC_SEARCH_LIBS([XCreatePixmap],[X11])
+AC_SEARCH_LIBS([hypot],[m])
+
+# # Checks for header files.
+# AC_CHECK_HEADERS([float.h malloc.h stdlib.h string.h unistd.h])
+# 
+# # Checks for typedefs, structures, and compiler characteristics.
+# 
+# # Checks for library functions.
+# AC_FUNC_MALLOC
+# AC_CHECK_FUNCS([floor strchr])
+
+# Epilogue
+AC_CONFIG_FILES([Makefile])
+AC_OUTPUT
